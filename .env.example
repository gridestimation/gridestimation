# Email Notification System Configuration
# Copy this file to .env and replace with your actual credentials

# EmailJS Configuration
# Get these from your EmailJS dashboard (https://www.emailjs.com/)
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_CONTACT_TEMPLATE_ID=contact_notification_template
VITE_EMAILJS_AUTO_REPLY_TEMPLATE_ID=auto_reply_template
VITE_EMAILJS_USER_ID=your_emailjs_user_id_here

# Google reCAPTCHA Configuration
# Get this from Google reCAPTCHA admin console (https://www.google.com/recaptcha/admin)
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here

# Email Configuration
# Your business email where notifications will be sent
VITE_BUSINESS_EMAIL=info@gridestimations.com
VITE_BUSINESS_PHONE=+1 (555) 123-4567

# Company Information
VITE_COMPANY_NAME=Grid Estimations
VITE_COMPANY_ADDRESS_LINE1=123 Solar Street
VITE_COMPANY_ADDRESS_LINE2=San Francisco, CA 94105

# Development/Production Environment
VITE_ENVIRONMENT=development

# Optional: Analytics and Monitoring
# VITE_GOOGLE_ANALYTICS_ID=your_ga_id_here
# VITE_SENTRY_DSN=your_sentry_dsn_here